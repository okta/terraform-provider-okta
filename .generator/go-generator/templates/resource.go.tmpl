		if !plan.{{$parent.GoField}}.{{.GoField}}.IsNull() && !plan.{{$parent.GoField}}.{{.GoField}}.IsUnknown() {
			nested{{$parent.GoField}}.Set{{.GoField}}(plan.{{$parent.GoField}}.{{.GoField}}.ValueBool())
		}
{{- end}}
{{- end}}
		updateBody.Set{{.GoField}}(*nested{{.GoField}})
	}
{{- end}}
{{- end}}
{{- if and .IsVariant .UnionTypeName}}
	updateReq = updateReq.{{.UpdateBodySetterMethod}}(okta.{{.UpdateSDKTypeName}}As{{.UnionTypeName}}(updateBody))
{{- else}}
	updateReq = updateReq.{{.UpdateBodySetterMethod}}(*updateBody)
{{- end}}
{{- end}}

	result, _, err := updateReq.Execute()
	if err != nil {
		resp.Diagnostics.AddError("Error updating {{.TFName}}", err.Error())
		return
	}

{{- if and .IsVariant .UnionTypeName}}
	// Unwrap the union type to access the concrete variant's fields.
	updateVariantObj := result.{{.DiscriminatorSchemaRef}}
	if updateVariantObj == nil {
		resp.Diagnostics.AddError("Error updating {{.TFName}}", "API returned a response for a different variant type")
