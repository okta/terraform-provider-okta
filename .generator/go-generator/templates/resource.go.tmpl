	}

	// Map API response fields to state (scalar types only)
	state.ID = types.StringValue(updateVariantObj.Get{{.IDField}}())
{{- range .Properties}}
{{- if not .WriteOnly}}
{{- if eq .GoType "types.String"}}
{{- if .IsDateTime}}
	state.{{.GoField}} = types.StringValue(updateVariantObj.Get{{.GoField}}().Format(time.RFC3339))
{{- else}}
	state.{{.GoField}} = types.StringValue(updateVariantObj.Get{{.GoField}}())
{{- end}}
{{- else if eq .GoType "types.Int64"}}
	state.{{.GoField}} = types.Int64Value(updateVariantObj.Get{{.GoField}}())
{{- else if eq .GoType "types.Bool"}}
	state.{{.GoField}} = types.BoolValue(updateVariantObj.Get{{.GoField}}())
{{- end}}
{{- end}}
{{- end}}
{{- else}}
	// Map API response fields to state (scalar types only; WriteOnly fields are skipped — response type doesn't have them)
	state.ID = types.StringValue(result.Get{{.IDField}}())
{{- range .Properties}}
{{- if not .WriteOnly}}
{{- if eq .GoType "types.String"}}
{{- if .IsDateTime}}
	state.{{.GoField}} = types.StringValue(result.Get{{.GoField}}().Format(time.RFC3339))
{{- else}}
	state.{{.GoField}} = types.StringValue(result.Get{{.GoField}}())
{{- end}}
{{- else if eq .GoType "types.Int64"}}
	state.{{.GoField}} = types.Int64Value(result.Get{{.GoField}}())
{{- else if eq .GoType "types.Bool"}}
	state.{{.GoField}} = types.BoolValue(result.Get{{.GoField}}())
{{- else if .SDKNestedTypeName}}
	state.{{.GoField}} = plan.{{.GoField}}
{{- end}}
{{- end}}
{{- end}}
{{- end}}

	resp.Diagnostics.Append(resp.State.Set(ctx, &state)...)
{{- else}}
	resp.Diagnostics.AddWarning(
